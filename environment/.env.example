# Environment Variables Example
# This file shows all available environment variables for the Docker Compose setup.
# For production, use .env.prod
# For local override development values, use .env.local (not versioned)

# ============================================
# Database Configuration
# ============================================
DB_HOST=db                          # Database host (container name or IP)
DB_PORT=3306                        # Database port
DB_USER=prod_user                   # Database user
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION # Database password (NEVER commit real passwords!)
# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=local_user
DB_PASSWORD=local_password_dev
DB_NAME=pixel_art_local

# Application Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

